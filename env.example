# The Odds API — Key Pool（ODDS_API_KEY_1 永遠必填；KEY2 建議）
ODDS_API_KEY_1=your_odds_api_key_1
ODDS_API_KEY_2=your_odds_api_key_2

# 輸出模式：true → log-only（不送 Telegram、不需 TG secrets）
#           false → 啟用真實 Telegram（TG_TOKEN / TG_CHAT 變必填）
DRY_RUN=true

# Telegram Bot（僅 DRY_RUN=false 時必填）
TG_TOKEN=your_telegram_bot_token
TG_CHAT=your_telegram_chat_id

# 除錯：輸出 API schema 樣本，不影響 production（選填）
DEBUG_API_SCHEMA=false
